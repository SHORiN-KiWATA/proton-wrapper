#!/usr/bin/env bash
set -euo pipefail

DEFAULT_PREFIX="${PROTON_PREFIX:-$HOME/.proton}"
XDG_DATA_HOME_VALUE="${XDG_DATA_HOME:-$HOME/.local/share}"
LOCAL_RUNNER_DIR="$XDG_DATA_HOME_VALUE/proton/runners"
STEAM_ROOT="${STEAM_COMPAT_CLIENT_INSTALL_PATH:-$HOME/.steam/root}"

ACTION=""
PRODUCT=""
VERSION="latest"
PREFIX="$DEFAULT_PREFIX"
RUNNER_ARG="${PROTON_RUNNER:-}"
DOWNLOAD_DIR=""
INSTALL_DIR=""
INSTALL_TO="local"
CLEAN=0
TARGET=""
TARGET_ARGS=()
LANG_OVERRIDE="${PROTON_LANG:-}"

RUNNER_TYPES=()
RUNNER_SOURCES=()
RUNNER_NAMES=()
RUNNER_PATHS=()
declare -A RUNNER_SEEN=()

ui_lang() {
  local locale="${LANG_OVERRIDE:-${LC_ALL:-${LC_MESSAGES:-${LANG:-}}}}"
  case "${locale,,}" in
    zh|zh_*|zh.*|zh-*) printf 'zh\n' ;;
    *) printf 'en\n' ;;
  esac
}

usage_en() {
  cat <<'EOF'
Usage:
  shorin-proton [options] app.exe [args...]
  shorin-proton --init [options]
  shorin-proton --winecfg [options]
  shorin-proton --list-runner
  shorin-proton --status
  shorin-proton --download ge|dw [-d DIR]
  shorin-proton -i ge|dw [--install-to local|steam|lutris]

Options:
  -p, --prefix DIR       prefix directory, default ~/.proton
  --runner PATH          runner path
  -d, --directory DIR    download directory
  -i, --install ge|dw    download and install a runner
  --install-to TARGET    local, steam, or lutris
  --version VERSION      release tag, default latest
  --lang zh|en           override help/status language
  --help-full            detailed help

Examples:
  shorin-proton game.exe
  shorin-proton -p ~/Games/game-prefix game.exe
  shorin-proton --download ge
  shorin-proton -i dw --install-to lutris
EOF
}

