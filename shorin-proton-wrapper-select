#!/usr/bin/env bash
set -euo pipefail

exe="${1:-}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
wrapper="shorin-proton-wrapper"

ui_lang() {
  local locale="${PROTON_LANG:-${LC_ALL:-${LC_MESSAGES:-${LANG:-}}}}"
  case "${locale,,}" in
    zh|zh_*|zh.*|zh-*) printf 'zh\n' ;;
    *) printf 'en\n' ;;
  esac
}

lang="$(ui_lang)"
if [[ "$lang" == "zh" ]]; then
  title="运行 Windows 软件"
  err_wrapper_required="shorin-proton-wrapper-select: 需要 shorin-proton-wrapper"
  err_no_exe="shorin-proton-wrapper-select: 未提供可执行文件"
  err_zenity_required="shorin-proton-wrapper-select: 需要 zenity"
  cached_text="已找到此程序的缓存环境。"
  cache_program_label="程序"
  cache_prefix_label="前置环境"
  cache_runner_label="运行器"
  cache_question="是否直接使用此环境运行？"
  action_run="直接运行"
  action_reselect="重新选择"
  action_cancel="取消"
  no_runner_text="没有找到 Proton 或 Wine 运行器。"
  runner_name_column="名称"
  runner_type_column="类型"
  runner_source_column="来源"
  runner_path_column="路径"
else
  title="Run Windows Software"
  err_wrapper_required="shorin-proton-wrapper-select: shorin-proton-wrapper is required"
  err_no_exe="shorin-proton-wrapper-select: no executable provided"
  err_zenity_required="shorin-proton-wrapper-select: zenity is required"
  cached_text="Cached environment found."
  cache_program_label="Program"
  cache_prefix_label="Prefix"
  cache_runner_label="Runner"
  cache_question="Run with this environment?"
  action_run="Run"
  action_reselect="Reselect"
  action_cancel="Cancel"
  no_runner_text="No Proton or Wine runner found."
  runner_name_column="Name"
  runner_type_column="Type"
  runner_source_column="Source"
  runner_path_column="Path"
fi

if [[ -x "$script_dir/shorin-proton-wrapper" ]]; then
  wrapper="$script_dir/shorin-proton-wrapper"
elif ! command -v shorin-proton-wrapper >/dev/null 2>&1; then
  printf '%s\n' "$err_wrapper_required" >&2
  exit 1
fi

if [[ -z "$exe" ]]; then
  printf '%s\n' "$err_no_exe" >&2
  exit 1
fi

if ! command -v zenity >/dev/null 2>&1; then
  printf '%s\n' "$err_zenity_required" >&2
  exit 1
fi

exe="$(realpath -m "$exe")"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/shorin-proton-wrapper/associations"
cache_key="$(printf '%s' "$exe" | sha256sum | cut -d ' ' -f 1)"
cache_file="$cache_dir/$cache_key.conf"

read_cache() {
  local line
  cache_prefix=""
  cache_runner=""
  [[ -r "$cache_file" ]] || return 1
  while IFS= read -r line; do
    case "$line" in
      prefix=*) cache_prefix="${line#prefix=}" ;;
      runner=*) cache_runner="${line#runner=}" ;;
    esac
  done < "$cache_file"
  [[ -n "$cache_prefix" && -n "$cache_runner" && -d "$cache_prefix" && -x "$cache_runner" ]]
}

if read_cache; then
  cache_message="$(printf '%s\n\n%s: %s\n%s: %s\n%s: %s\n\n%s' \
    "$cached_text" \
    "$cache_program_label" "$exe" \
    "$cache_prefix_label" "$cache_prefix" \
    "$cache_runner_label" "$cache_runner" \
    "$cache_question")"
  set +e
  action="$(zenity \
    --question \
    --title="$title" \
    --icon=shorin-proton \
    --text="$cache_message" \
    --width=820 \
    --ok-label="$action_run" \
    --cancel-label="$action_cancel" \
    --extra-button="$action_reselect")"
  status=$?
  set -e
  if [[ "$action" == "$action_reselect" ]]; then
    :
  elif [[ $status -eq 0 ]]; then
    exec "$wrapper" -p "$cache_prefix" --runner "$cache_runner" "$exe"
  else
    exit 0
  fi
fi

prefix="$(zenity --file-selection --directory --title="$title")" || exit 1

rows=()
name=""
type=""
source=""
while IFS= read -r line; do
  if [[ "$line" != *:* ]]; then
    name="${line#"${line%%[![:space:]]*}"}"
    name="${name#\* }"
  elif [[ "$line" == "      type:   "* ]]; then
    type="${line#      type:   }"
  elif [[ "$line" == "      source: "* ]]; then
    source="${line#      source: }"
  elif [[ "$line" == "      path:   "* ]]; then
    path="${line#      path:   }"
    rows+=("$name" "$type" "$source" "$path")
  fi
done < <("$wrapper" --list-runner)

if [[ ${#rows[@]} -eq 0 ]]; then
  zenity --error --title="$title" --icon=shorin-proton --text="$no_runner_text"
  exit 1
fi

runner="$(zenity \
  --list \
  --title="$title" \
  --width=900 \
  --height=420 \
  --column="$runner_name_column" \
  --column="$runner_type_column" \
  --column="$runner_source_column" \
  --column="$runner_path_column" \
  --print-column=4 \
  "${rows[@]}")" || exit 1

mkdir -p "$cache_dir"
{
  printf 'exe=%s\n' "$exe"
  printf 'prefix=%s\n' "$prefix"
  printf 'runner=%s\n' "$runner"
} > "$cache_file"

exec "$wrapper" -p "$prefix" --runner "$runner" "$exe"
