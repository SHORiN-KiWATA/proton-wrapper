def resolve_wrapper() -> str:
    env = os.environ.get("SHORIN_PROTON_WRAPPER")
    if env:
        return env
    candidate = Path(__file__).resolve().with_name("shorin-proton-wrapper")
    if candidate.is_file() and os.access(candidate, os.X_OK):
        return str(candidate)
    return "shorin-proton-wrapper"


def cache_file_for(exe: Path) -> Path:
    cache_home = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"))
    cache_dir = cache_home / "shorin-proton-wrapper" / "associations"
    cache_dir.mkdir(parents=True, exist_ok=True)
    key = hashlib.sha256(str(exe).encode()).hexdigest()
    return cache_dir / f"{key}.conf"


def read_cache(path: Path):
    if not path.is_file():
        return None
    data = {}
    for line in path.read_text(errors="ignore").splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            data[key] = value
    prefix = data.get("prefix", "")
    runner = data.get("runner", "")
    if prefix and runner and Path(prefix).is_dir() and os.access(runner, os.X_OK):
        return {
            "prefix": prefix,
            "runner": runner,
            "gamescope": data.get("gamescope", "0"),
            "gamescope_fullscreen": data.get("gamescope_fullscreen", "1"),
            "gamescope_res": data.get("gamescope_res", ""),
            "gamescope_fps": data.get("gamescope_fps", ""),
            "gamescope_fsr": data.get("gamescope_fsr", "0"),
            "gamescope_args": data.get("gamescope_args", ""),
        }
    return None


def write_cache(path: Path, exe: Path, prefix: str, runner: str, options: dict):
    path.write_text(
        f"exe={exe}\n"
        f"prefix={prefix}\n"
        f"runner={runner}\n"
        f"gamescope={options.get('gamescope', '0')}\n"
        f"gamescope_fullscreen={options.get('gamescope_fullscreen', '1')}\n"
        f"gamescope_res={options.get('gamescope_res', '')}\n"
        f"gamescope_fps={options.get('gamescope_fps', '')}\n"
        f"gamescope_fsr={options.get('gamescope_fsr', '0')}\n"
        f"gamescope_args={options.get('gamescope_args', '')}\n"
    )


def normalize_exe_arg(value: str) -> Path:
    value = value.strip()
    parsed = urlparse(value)
    if parsed.scheme == "file":
        return Path(unquote(parsed.path)).expanduser().resolve(strict=False)
    return Path(value).expanduser().resolve(strict=False)


def parse_runners(output: str):
    runners = []
    name = kind = source = ""
    for line in output.splitlines():
        if not line.strip():
            continue
        if ":" not in line:
            name = line.strip().removeprefix("* ").strip()
        elif line.startswith("      type:   "):
            kind = line.removeprefix("      type:   ")
        elif line.startswith("      source: "):
            source = line.removeprefix("      source: ")
        elif line.startswith("      path:   "):
            runners.append({
                "name": name,
                "type": kind,
                "source": source,
                "path": line.removeprefix("      path:   "),
            })
    return runners


def load_runners(wrapper: str):
    try:
        result = subprocess.run([wrapper, "--list-runner"], check=False, text=True, capture_output=True)
    except OSError:
        return []
    return parse_runners(result.stdout)


def gamescope_args(options: dict) -> list[str]:
    if options.get("gamescope") != "1":
        return []
    args = ["--gamescope"]
    if options.get("gamescope_fullscreen", "1") != "1":
        args.append("--gamescope-windowed")
    if options.get("gamescope_res"):
        args.extend(["--gamescope-res", options["gamescope_res"]])
    if options.get("gamescope_fps"):
        args.extend(["--gamescope-fps", options["gamescope_fps"]])
    if options.get("gamescope_fsr") == "1":
        args.append("--gamescope-fsr")
    if options.get("gamescope_args"):
        args.extend(["--gamescope-args", options["gamescope_args"]])
    return args


def gamescope_summary(options: dict) -> str:
    if options.get("gamescope") != "1":
        return "Gamescope: " + ("关闭" if ZH else "off")
    parts = ["Gamescope"]
    parts.append("全屏" if options.get("gamescope_fullscreen", "1") == "1" and ZH else "fullscreen" if options.get("gamescope_fullscreen", "1") == "1" else "窗口" if ZH else "windowed")
    if options.get("gamescope_res"):
        parts.append(options["gamescope_res"])
    if options.get("gamescope_fps"):
        parts.append((options["gamescope_fps"] + " FPS"))
    if options.get("gamescope_fsr") == "1":
        parts.append("FSR")
    if options.get("gamescope_args"):
        parts.append(options["gamescope_args"])
    return ", ".join(parts)


class SelectorApp(Gtk.Application):
    def __init__(self, exe: Path):
        super().__init__(application_id="io.github.shorin.proton_wrapper_select")
        self.exe = exe
        self.wrapper = resolve_wrapper()
        self.cache_file = cache_file_for(exe)
        self.window = None
        self.prefix_entry = None
        self.selected_runner = None
        self.gamescope_check = None
        self.fullscreen_check = None
        self.res_combo = None
        self.custom_res_entry = None
        self.fps_combo = None
        self.custom_fps_entry = None
        self.fsr_check = None
        self.extra_args_entry = None

    def do_activate(self):
        install_css()
        cache = read_cache(self.cache_file)
        if cache:
            self.show_cache_window(cache)
        else:
            self.show_select_window()

    def show_error(self, message: str):
        dialog = Gtk.MessageDialog(
            transient_for=self.window,
            modal=True,
            message_type=Gtk.MessageType.ERROR,
            buttons=Gtk.ButtonsType.OK,
            text=message,
        )
        dialog.connect("response", lambda d, _r: d.close())
        dialog.present()

    def run_with(self, prefix: str, runner: str, options: dict | None = None):
        options = options or {}
        command = [self.wrapper, "-p", prefix, "--runner", runner]
        command.extend(gamescope_args(options))
        command.append(str(self.exe))
        subprocess.Popen(command)
        self.quit()

