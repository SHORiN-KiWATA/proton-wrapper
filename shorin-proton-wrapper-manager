    def apps_state_signature(self, prefix: Path, apps: list[dict[str, str]], running: dict[str, dict[str, object]]) -> tuple:
        items = []
        for app in apps:
            app_id = app_identity(prefix, Path(app["path"]))
            running_app = running.get(app_id)
            log_path = Path(str(running_app.get("log", ""))) if running_app and running_app.get("log") else latest_log_for_app(app_id)
            items.append((
                app_id,
                app_display_name(app),
                app.get("path", ""),
                app.get("runner", ""),
                app.get("kind", ""),
                bool(running_app),
                tuple(sorted(running_app.get("pids", []))) if running_app else (),
                str(log_path or ""),
            ))
        return (str(prefix), tuple(items))

    def install_dirs_state_signature(self, prefix: Path, dirs: list[dict[str, object]]) -> tuple:
        items = []
        for item in dirs:
            items.append((
                str(item.get("path", "")),
                item.get("exe_count", 0),
                item.get("linked_count", 0),
                int(float(item.get("mtime", 0))),
            ))
        return (str(prefix), tuple(items))

