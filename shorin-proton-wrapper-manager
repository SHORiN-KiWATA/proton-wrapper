    def on_rename_app_response(self, dialog, response, app: dict[str, str], entry: Gtk.Entry) -> None:
        if response == Gtk.ResponseType.ACCEPT:
            old_name = app_display_name(app)
            name = entry.get_text().strip() or app_display_name(app)
            renamed_icons = rename_icon_cache_files(old_name, name)
            cache_entry = app_cache_entry(self.page_prefix("apps"), app)
            cache_entry["name"] = name
            write_cache_entry(cache_entry)
            desktop = exported_desktop_path(self.page_prefix("apps"), app)
            if desktop.is_file():
                rewrite_desktop_name(desktop, name)
                rewrite_desktop_icon(desktop, renamed_icons)
            self.set_status(f"{TEXT['rename']}: {name}")
        dialog.destroy()
        self.refresh_after_mutation()

