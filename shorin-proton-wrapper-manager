    def check_for_updates(self) -> bool:
        if self.update_running:
            return True
        def worker():
            try:
                result = subprocess.run(
                    [str(self.wrapper), "--check-update"],
                    capture_output=True, text=True, timeout=30,
                )
                output = result.stdout.strip() if result.returncode == 0 else ""
            except Exception:
                output = ""
            GLib.idle_add(self._on_update_check_done, output)
        threading.Thread(target=worker, daemon=True).start()
        return True

    def _on_update_check_done(self, output: str) -> bool:
        if not self.update_button or self.update_running:
            return False
        if output:
            self.update_button.set_visible(True)
            self.update_button.set_tooltip_text(output)
        else:
            self.update_button.set_visible(False)
        return False

    def on_update_clicked(self) -> None:
        if self.update_running or not self.update_button:
            return
        tooltip = self.update_button.get_tooltip_text() or ""
        dialog = Gtk.MessageDialog(
            transient_for=self.window,
            modal=True,
            message_type=Gtk.MessageType.QUESTION,
            buttons=Gtk.ButtonsType.OK_CANCEL,
            text=TEXT["update_confirm_title"],
            secondary_text=TEXT["update_confirm_msg"] + "\n\n" + tooltip,
        )
        dialog.connect("response", lambda _d, response: self._on_update_dialog_response(_d, response))
        dialog.present()

    def _on_update_dialog_response(self, dialog: Gtk.MessageDialog, response: int) -> None:
        dialog.destroy()
        if response != Gtk.ResponseType.OK:
            return
        self.update_running = True
        self.update_button.set_label(TEXT["updating"])
        self.update_button.set_sensitive(False)
        self.set_status(TEXT["updating"])

        def worker():
            try:
                result = subprocess.run(
                    [str(self.wrapper), "--update"],
                    capture_output=True, text=True, timeout=600,
                )
                success = result.returncode == 0
            except Exception:
                success = False
            GLib.idle_add(self._on_update_complete, success)

        threading.Thread(target=worker, daemon=True).start()

    def _on_update_complete(self, success: bool) -> bool:
        self.update_running = False
        self.update_button.set_sensitive(True)
        self.update_button.set_label(TEXT["update_available"])
        if success:
            self.set_status(TEXT["update_done"])
        else:
            self.set_status(TEXT["update_failed"])
        self.check_for_updates()
        return False

