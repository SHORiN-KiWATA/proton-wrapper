        visible = self.stack.get_visible_child_name() if self.stack else "apps"
        self.update_prefix_path_label(combo, "processes" if visible == "processes" else visible)
        self.refresh_all()

    def current_prefix(self) -> Path:
        combo = self.current_prefix_combo()
        text = combo.get_active_text() if combo else ""
        visible = self.stack.get_visible_child_name() if self.stack else "apps"
        if visible == "processes" and text in self.process_prefix_display_paths:
            return self.process_prefix_display_paths[text]
        return expand_path(text or Path.home() / ".proton")

    def page_prefix(self, page: str) -> Path:
        if page == "processes":
            combo = self.process_prefix_combo
        elif page == "install_dirs":
            combo = self.install_dirs_prefix_combo
        else:
            combo = self.apps_prefix_combo
        text = combo.get_active_text() if combo else ""
        if page == "processes" and text in self.process_prefix_display_paths:
            return self.process_prefix_display_paths[text]
        return expand_path(text or Path.home() / ".proton")

    def current_prefix_combo(self) -> Gtk.ComboBoxText | None:
        visible = self.stack.get_visible_child_name() if self.stack else "apps"
        if visible == "processes":
            return self.process_prefix_combo
        if visible == "install_dirs":
            return self.install_dirs_prefix_combo
        return self.apps_prefix_combo

    def reload_prefixes(self) -> None:
        self.prefixes = collect_prefixes()
        process_prefixes = collect_process_prefixes()
        process_labels = unique_process_prefix_labels(process_prefixes)
        old_process_display_paths = self.process_prefix_display_paths
        self.process_prefix_display_paths = {label: prefix for label, prefix in process_labels}
        for combo, entries in (
            (self.apps_prefix_combo, [(str(prefix), prefix) for prefix in self.prefixes]),
            (self.install_dirs_prefix_combo, [(str(prefix), prefix) for prefix in self.prefixes]),
            (self.process_prefix_combo, process_labels),
        ):
            if not combo:
                continue
            current = combo.get_active_text()
            current_prefix = old_process_display_paths.get(current) if combo == self.process_prefix_combo else None
            combo.remove_all()
            active_index = 0
            for index, (label, prefix) in enumerate(entries):
                combo.append_text(label)
                if label == current or (current_prefix and prefix == current_prefix):
                    active_index = index
            combo.set_active(active_index)
            if combo == self.process_prefix_combo:
                self.update_prefix_path_label(combo, "processes")

    def refresh_all(self) -> None:
        if self.popover_open:
            return
        visible = self.stack.get_visible_child_name() if self.stack else "apps"
        if visible == "processes":
            self.refresh_processes()
        elif visible == "install_dirs":
            self.refresh_install_dirs()
        else:
            self.refresh_apps()

    def refresh_process_page(self) -> None:
        self.reload_prefixes()
        self.refresh_processes()

    def auto_refresh(self) -> bool:
        if self.popover_open:
            return True
        self.refresh_tick += 1
        visible = self.stack.get_visible_child_name() if self.stack else ""
        if visible == "processes":
            if self.refresh_tick % 2 == 0:
                self.reload_prefixes()
            self.refresh_processes()
        elif visible == "install_dirs":
            if self.refresh_tick % 4 == 0:
                self.refresh_install_dirs()
        elif visible == "apps":
            if self.refresh_tick % 3 == 0:
                self.refresh_apps()
        return True

