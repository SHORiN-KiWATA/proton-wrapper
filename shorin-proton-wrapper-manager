def shortcut_roots(prefix: Path) -> list[tuple[str, Path]]:
    pfx = prefix / "pfx" / "drive_c"
    return [
        ("Desktop", pfx / "users" / os.environ.get("USER", "") / "Desktop"),
        ("Start Menu", pfx / "users" / os.environ.get("USER", "") / "AppData/Roaming/Microsoft/Windows/Start Menu/Programs"),
        ("All Users", pfx / "ProgramData/Microsoft/Windows/Start Menu/Programs"),
    ]


def scan_apps(prefix: Path) -> list[dict[str, str]]:
    prefix = expand_path(prefix)
    apps = []
    seen = set()
    shortcut_targets = set()
    for source, root in shortcut_roots(prefix):
        if not root.is_dir():
            continue
        for lnk in sorted(root.rglob("*.lnk"), key=lambda item: str(item).lower()):
            real = str(lnk.resolve(strict=False))
            if real in seen:
                continue
            seen.add(real)
            target = parse_lnk_target(lnk)
            target_path = windows_path_to_linux(prefix, target) if target else None
            if target_path:
                shortcut_targets.add(str(target_path.resolve(strict=False)))
            shortcut_cache = read_key_values(cache_file_for_path(lnk))
            apps.append({
                "name": lnk.stem,
                "display_name": shortcut_cache.get("name", lnk.stem),
                "source": source,
                "path": str(lnk),
                "target_exe": str(target_path) if target_path else "",
                "file": str(cache_file_for_path(lnk)) if shortcut_cache else "",
                "kind": "shortcut",
            })
    for entry in collect_cache_entries():
        entry_prefix = entry.get("prefix", "")
        exe = entry.get("exe", "")
        if not entry_prefix or not exe:
            continue
        if expand_path(entry_prefix) != prefix:
            continue
        exe_path = expand_path(exe)
        real = str(exe_path.resolve(strict=False))
        if real in seen or real in shortcut_targets:
            continue
        seen.add(real)
        display_name = inferred_exe_name(exe_path, prefix)
        apps.append({
            "name": Path(exe).stem,
            "display_name": entry.get("name", display_name),
            "source": entry.get("source", "configured"),
            "path": str(exe_path),
            "runner": entry.get("runner", ""),
            "prefix": entry.get("prefix", str(prefix)),
            "file": entry.get("file", ""),
            "gamescope": entry.get("gamescope", "0"),
            "gamescope_fullscreen": entry.get("gamescope_fullscreen", "1"),
            "gamescope_res": entry.get("gamescope_res", ""),
            "gamescope_fps": entry.get("gamescope_fps", ""),
            "gamescope_fsr": entry.get("gamescope_fsr", "0"),
            "gamescope_args": entry.get("gamescope_args", ""),
            "mangohud": entry.get("mangohud", "0"),
            "env_vars": entry.get("env_vars", ""),
            "kind": "saved-config",
        })
    return apps


def desktop_matches_app(path: Path, prefix: Path, app: dict[str, str]) -> bool:
    data = read_key_values(path)
    return (
        data.get("X-Shorin-Proton-Wrapper-ID") == app_identity(prefix, Path(app["path"]))
        or (data.get("X-Shorin-Proton-Wrapper-Prefix") == str(prefix) and data.get("X-Shorin-Proton-Wrapper-Path") == app["path"])
    )


def exported_desktop_path(prefix: Path, app: dict[str, str], display_name: str | None = None) -> Path:
    preferred, hashed = desktop_paths_for_app(prefix, app, display_name)
    if not preferred.exists() or desktop_matches_app(preferred, prefix, app):
        return preferred
    return hashed


def exported_icon_path(prefix: Path, app: dict[str, str], display_name: str | None = None) -> Path:
    preferred, hashed = icon_paths_for_app(prefix, app, display_name)
    desktop = exported_desktop_path(prefix, app, display_name)
    return preferred if desktop.stem == preferred.stem else hashed


def export_app(prefix: Path, app: dict[str, str], wrapper: str, display_name: str | None = None) -> Path:
    lnk = Path(app["path"])
    name = (display_name or app_display_name(app)).strip() or app_display_name(app)
    target = exported_desktop_path(prefix, app, name)
    target_dir = target.parent
    target_dir.mkdir(parents=True, exist_ok=True)
    exec_line = f"{desktop_arg(wrapper)} -p {desktop_arg(prefix)} {desktop_arg(lnk)}"
    icon_path = exported_icon_path(prefix, app, name)
    icon_app = dict(app)
    icon_app["display_name"] = name
    icon = icon_for_app(prefix, icon_app, icon_path.parent)
    if icon != "shorin-proton" and Path(icon).is_file() and Path(icon) != icon_path:
        icon_path.parent.mkdir(parents=True, exist_ok=True)
        icon_path.write_bytes(Path(icon).read_bytes())
        icon = str(icon_path)
    target.write_text(
        "[Desktop Entry]\n"
        "Type=Application\n"
        f"Name={name}\n"
        f"Comment=Run {name} with shorin-proton-wrapper\n"
        f"Exec={exec_line}\n"
        f"Icon={icon}\n"
        "Terminal=false\n"
        "Categories=Utility;X-Wine;\n"
        f"X-Shorin-Proton-Wrapper-ID={app_identity(prefix, lnk)}\n"
        f"X-Shorin-Proton-Wrapper-Prefix={prefix}\n"
        f"X-Shorin-Proton-Wrapper-Path={lnk}\n",
        encoding="utf-8",
    )
    target.chmod(0o644)
    return target


def delete_exported_app(prefix: Path, app: dict[str, str]) -> Path:
    target = exported_desktop_path(prefix, app)
    target.unlink(missing_ok=True)
    return target


def delete_exported_icon(prefix: Path, app: dict[str, str]) -> Path:
    target = exported_icon_path(prefix, app)
    target.unlink(missing_ok=True)
    return target


def read_desktop_name(path: Path) -> str:
    if not path.is_file():
        return ""
    for line in path.read_text(errors="ignore").splitlines():
        if line.startswith("Name="):
            return line.split("=", 1)[1]
    return ""


def rewrite_desktop_name(path: Path, name: str) -> None:
    lines = []
    changed = False
    for line in path.read_text(errors="ignore").splitlines():
        if line.startswith("Name="):
            lines.append(f"Name={name}")
            changed = True
        else:
            lines.append(line)
    if not changed:
        lines.insert(2, f"Name={name}")
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def rename_icon_cache_files(old_name: str, new_name: str) -> dict[str, str]:
    old_base = safe_filename(old_name)
    new_base = safe_filename(new_name)
    renamed = {}
    if old_base == new_base:
        return renamed
    for directory in (gui_icon_dir(), exported_icon_dir()):
        if not directory.is_dir():
            continue
        for icon in list(directory.glob(f"{old_base}.png")) + list(directory.glob(f"{old_base}-*.png")):
            suffix = icon.name[len(old_base):]
            target = icon.with_name(f"{new_base}{suffix}")
            if target.exists():
                renamed[str(icon)] = str(target)
                continue
            try:
                icon.rename(target)
            except OSError:
                continue
            renamed[str(icon)] = str(target)
    return renamed


def rewrite_desktop_icon(path: Path, renamed_icons: dict[str, str]) -> None:
    if not path.is_file() or not renamed_icons:
        return
    lines = []
    changed = False
    for line in path.read_text(errors="ignore").splitlines():
        if line.startswith("Icon="):
            value = line.split("=", 1)[1]
            replacement = renamed_icons.get(value)
            if replacement:
                lines.append(f"Icon={replacement}")
                changed = True
                continue
        lines.append(line)
    if changed:
        path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def maybe_update_desktop_database() -> None:
    if not shutil_which("update-desktop-database"):
        return
    subprocess.run(["update-desktop-database", str(data_home() / "applications")], check=False)


def shutil_which(name: str) -> str | None:
    for part in os.environ.get("PATH", "").split(os.pathsep):
        candidate = Path(part) / name
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate)
    return None


def process_start_time(pid: int) -> str:
    try:
        started = Path(f"/proc/{pid}").stat().st_ctime
    except OSError:
        return ""
    seconds = max(0, int(time.time() - started))
    if seconds < 60:
        return f"{seconds}s"
    if seconds < 3600:
        return f"{seconds // 60}m"
    return f"{seconds // 3600}h{seconds % 3600 // 60}m"


def scan_processes(prefix: Path) -> list[dict[str, str]]:
    prefix = expand_path(prefix)
    wineprefixes = []
    if looks_like_compat_prefix(prefix) or not looks_like_wine_prefix(prefix):
        wineprefixes.append(str(prefix / "pfx"))
    if looks_like_wine_prefix(prefix):
        wineprefixes.append(str(prefix))
    steam_data = str(prefix)
    result = []
    for proc in Path("/proc").iterdir():
        if not proc.name.isdigit():
            continue
        pid = int(proc.name)
        if pid == os.getpid():
            continue
        try:
            environ = (proc / "environ").read_bytes().split(b"\0")
        except OSError:
            continue
        env = {}
        matched = False
        for item in environ:
            if b"=" in item:
                key, value = item.split(b"=", 1)
                env[key.decode(errors="replace")] = value.decode(errors="replace")
        if env.get("WINEPREFIX", "") in wineprefixes:
            matched = True
        if env.get("STEAM_COMPAT_DATA_PATH", "") == steam_data:
            matched = True
        if env.get("SHORIN_PROTON_WRAPPER_PREFIX") == str(prefix):
            matched = True
        if not matched:
            continue
        try:
            command = (proc / "cmdline").read_bytes().replace(b"\0", b" ").decode(errors="replace").strip()
        except OSError:
            command = ""
        try:
            name = (proc / "comm").read_text(errors="replace").strip()
        except OSError:
            name = ""
        result.append({
            "pid": str(pid),
            "name": name,
            "command": command or name,
            "age": process_start_time(pid),
            "app_id": env.get("SHORIN_PROTON_WRAPPER_APP_ID", ""),
            "app_path": env.get("SHORIN_PROTON_WRAPPER_APP_PATH", ""),
            "log": env.get("SHORIN_PROTON_WRAPPER_LOG", ""),
        })
    return sorted(result, key=lambda item: int(item["pid"]))


def running_apps_for_prefix(prefix: Path) -> dict[str, dict[str, object]]:
    running: dict[str, dict[str, object]] = {}
    for proc in scan_processes(prefix):
        app_id = proc.get("app_id", "")
        if not app_id:
            continue
        item = running.setdefault(app_id, {"pids": [], "log": proc.get("log", ""), "path": proc.get("app_path", "")})
        item["pids"].append(proc["pid"])
        if proc.get("log"):
            item["log"] = proc["log"]
    return running


def kill_pid(pid: int, force: bool = False) -> None:
    os.kill(pid, signal.SIGKILL if force else signal.SIGTERM)


def collect_cache_entries() -> list[dict[str, str]]:
    entries = []
    for conf in sorted(association_dir().glob("*.conf"), key=lambda item: item.stat().st_mtime, reverse=True):
        data = read_key_values(conf)
        exe = data.get("exe", "")
        if not exe:
            continue
        if not expand_path(exe).exists():
            conf.unlink(missing_ok=True)
            continue
        data["file"] = str(conf)
        prefix = expand_path(data.get("prefix", Path.home() / ".proton"))
        data["name"] = data.get("name") or inferred_exe_name(expand_path(exe), prefix)
        data["source"] = data.get("source") or "configured"
        entries.append(data)
    return entries


def write_cache_entry(entry: dict[str, str]) -> None:
    path = Path(entry.get("file") or cache_file_for_path(entry.get("exe", "")))
    path.parent.mkdir(parents=True, exist_ok=True)
    old_path = Path(entry.get("file", "")) if entry.get("file") else None
    new_path = cache_file_for_path(entry.get("exe", ""))
    if new_path != path:
        path = new_path
    entry["file"] = str(path)
    keys = [
        "name", "exe", "prefix", "runner", "gamescope", "gamescope_fullscreen", "gamescope_res",
        "gamescope_fps", "gamescope_fsr", "gamescope_args", "mangohud", "env_vars", "source",
    ]
    path.write_text(
        "".join(f"{key}={quote(entry.get(key, '')) if key == 'env_vars' else entry.get(key, '')}\n" for key in keys),
        encoding="utf-8",
    )
    if old_path and old_path != path:
        old_path.unlink(missing_ok=True)


