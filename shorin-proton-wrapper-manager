    def close_running_app(self, app_id: str) -> None:
        killed = 0
        for proc in scan_processes(self.page_prefix("apps")):
            if proc.get("app_id") != app_id:
                continue
            try:
                kill_pid(int(proc["pid"]), True)
                killed += 1
            except OSError:
                pass
        self.set_status(f"{TEXT['close']}: {killed}")
        self.refresh_apps(force=True)
        self.refresh_processes()

