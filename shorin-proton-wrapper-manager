def normalize_match_name(value: str) -> str:
    return "".join(char.lower() for char in value if char.isalnum())


def is_ignored_install_dir(path: Path) -> bool:
    lower = path.name.lower().strip()
    if not lower or lower in IGNORED_INSTALL_DIR_NAMES:
        return True
    return lower.startswith("windows ") or any(word in lower for word in ("redist", "vcredist", "webview", "crashreport", "uninstall"))


def is_low_value_exe(path: Path) -> bool:
    lower = path.stem.lower().replace("-", "_").replace(" ", "_")
    return any(word in lower for word in LOW_VALUE_EXE_WORDS)


def windows_display_path(prefix: Path, path: Path) -> str:
    prefix = expand_path(prefix)
    path = expand_path(path)
    drive_c = prefix / "pfx" / "drive_c"
    try:
        return "C:\\" + str(path.relative_to(drive_c)).replace("/", "\\")
    except ValueError:
        return str(path)


def safe_relative_path(root: Path, path: Path) -> str:
    try:
        rel = path.relative_to(root)
    except ValueError:
        return str(path)
    text = str(rel.parent)
    return "根目录" if ZH and text == "." else "root" if text == "." else text


def file_size_label(path: Path) -> str:
    try:
        size = path.stat().st_size
    except OSError:
        return ""
    if size >= 1024 * 1024:
        return f"{size / 1024 / 1024:.1f} MB"
    if size >= 1024:
        return f"{size / 1024:.0f} KB"
    return f"{size} B"


def scan_exes_in_dir(directory: Path, limit: int = 300) -> list[dict[str, object]]:
    directory = expand_path(directory)
    if not directory.is_dir():
        return []
    root_name = normalize_match_name(directory.name)
    result = []
    scanned = 0
    for exe in sorted(directory.rglob("*.exe"), key=lambda item: str(item).lower()):
        scanned += 1
        if scanned > limit:
            break
        if not exe.is_file():
            continue
        low_value = is_low_value_exe(exe)
        score = 0
        stem = normalize_match_name(exe.stem)
        if stem and root_name and (stem == root_name or stem in root_name or root_name in stem):
            score += 80
        if exe.parent == directory:
            score += 35
        if exe.parent.name.lower() in {"bin", "game", "games", "launcher", "client"}:
            score += 12
        try:
            if exe.stat().st_size >= 1024 * 1024:
                score += 10
        except OSError:
            pass
        if low_value:
            score -= 100
        result.append({
            "path": exe,
            "name": exe.name,
            "low_value": low_value,
            "score": score,
            "detail": f"{safe_relative_path(directory, exe)} · {file_size_label(exe)}".strip(" ·"),
        })
    return sorted(result, key=lambda item: (-int(item["score"]), bool(item["low_value"]), str(item["path"]).lower()))


def app_path_under_dir(app: dict[str, str], directory: Path) -> bool:
    values = [app.get("path", ""), app.get("target_exe", "")]
    for value in values:
        if not value:
            continue
        try:
            expand_path(value).relative_to(directory)
            return True
        except ValueError:
            continue
    return False


def scan_install_dirs(prefix: Path, apps: list[dict[str, str]] | None = None) -> list[dict[str, object]]:
    prefix = expand_path(prefix)
    apps = apps or scan_apps(prefix)
    roots = windows_install_roots(prefix) + [prefix / "pfx" / "drive_c" / "ProgramData"]
    result = []
    seen = set()
    for root in roots:
        if not root.is_dir():
            continue
        try:
            children = sorted((item for item in root.iterdir() if item.is_dir()), key=lambda item: item.name.lower())
        except OSError:
            continue
        for child in children:
            child = expand_path(child)
            key = str(child)
            if key in seen or is_ignored_install_dir(child):
                continue
            seen.add(key)
            exes = scan_exes_in_dir(child, limit=120)
            linked = sum(1 for app in apps if app_path_under_dir(app, child))
            if not exes and linked == 0:
                continue
            result.append({
                "name": child.name,
                "path": child,
                "prefix": prefix,
                "exe_count": len(exes),
                "linked_count": linked,
                "mtime": child.stat().st_mtime if child.exists() else 0,
            })
    return sorted(result, key=lambda item: (-int(item["linked_count"]), -float(item["mtime"]), str(item["name"]).lower()))


def can_delete_install_dir(prefix: Path, directory: Path) -> bool:
    prefix = expand_path(prefix)
    directory = expand_path(directory)
    roots = windows_install_roots(prefix) + [prefix / "pfx" / "drive_c" / "ProgramData"]
    blocked = {
        prefix,
        prefix / "pfx",
        prefix / "pfx" / "drive_c",
        prefix / "pfx" / "drive_c" / "Program Files",
        prefix / "pfx" / "drive_c" / "Program Files (x86)",
        prefix / "pfx" / "drive_c" / "ProgramData",
        prefix / "pfx" / "drive_c" / "users",
        prefix / "pfx" / "drive_c" / "windows",
    }
    if directory in blocked or directory.is_symlink() or not directory.is_dir():
        return False
    for root in roots:
        root = expand_path(root)
        try:
            rel = directory.relative_to(root)
        except ValueError:
            continue
        return bool(rel.parts) and rel.parts[0] not in {"", ".", ".."}
    return False


def can_delete_prefix(prefix: Path) -> bool:
    prefix = expand_path(prefix)
    home = expand_path(Path.home())
    blocked = {
        home,
        home / ".local",
        home / ".local/share",
        home / ".local/share/Steam",
        home / ".local/share/Steam/steamapps",
        home / ".local/share/Steam/steamapps/compatdata",
        home / ".steam",
        home / ".steam/steam",
        home / ".steam/steam/steamapps",
        home / ".steam/steam/steamapps/compatdata",
        home / ".var",
        home / ".var/app",
        home / ".var/app/com.valvesoftware.Steam",
        home / ".var/app/com.valvesoftware.Steam/.local/share/Steam",
        home / ".var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps",
        home / ".var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/compatdata",
        Path("/"),
    }
    return prefix.is_dir() and not prefix.is_symlink() and prefix not in blocked and (looks_like_compat_prefix(prefix) or looks_like_wine_prefix(prefix))


def under_known_install_root(prefix: Path, path: Path) -> bool:
    path = expand_path(path)
    for root in windows_install_roots(prefix):
        try:
            path.relative_to(root)
            return True
        except ValueError:
            continue
    return False


def inferred_exe_name(path: Path, prefix: Path | None = None) -> str:
    stem = path.stem
    if stem.lower() not in GENERIC_EXE_NAMES:
        return stem
    if prefix is None or not under_known_install_root(prefix, path):
        return stem
    for parent in path.parents:
        name = parent.name
        lower = name.lower()
        if not name or lower in GENERIC_DIR_NAMES or version_like(name):
            continue
        if lower in {"program files", "program files (x86)", "drive_c", "pfx"}:
            break
        return name
    return stem


