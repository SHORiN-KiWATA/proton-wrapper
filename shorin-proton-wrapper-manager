def expand_path(value: str | Path) -> Path:
    return Path(value).expanduser().resolve(strict=False)


def cache_home() -> Path:
    return Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"))


def data_home() -> Path:
    return Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share"))


def association_dir() -> Path:
    return cache_home() / "shorin-proton-wrapper" / "associations"


def gui_icon_dir() -> Path:
    return cache_home() / "shorin-proton-wrapper" / "icons"


def exported_icon_dir() -> Path:
    return data_home() / "icons" / "shorin-proton-wrapper" / "apps"


def exported_app_dir() -> Path:
    return data_home() / "applications" / "shorin-proton-wrapper"


def run_log_root() -> Path:
    return cache_home() / "shorin-proton-wrapper" / "logs"


def app_log_dir(app_id: str) -> Path:
    return run_log_root() / app_id


def latest_log_for_app(app_id: str) -> Path | None:
    directory = app_log_dir(app_id)
    latest = directory / "latest.log"
    if latest.is_file():
        return latest
    if not directory.is_dir():
        return None
    logs = sorted(directory.glob("*.log"), key=lambda item: item.stat().st_mtime, reverse=True)
    return logs[0] if logs else None


def resolve_sibling(name: str) -> str:
    candidate = Path(__file__).resolve().with_name(name)
    if candidate.is_file() and os.access(candidate, os.X_OK):
        return str(candidate)
    return name


def read_key_values(path: Path) -> dict[str, str]:
    data = {}
    if not path.is_file():
        return data
    for line in path.read_text(errors="ignore").splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        if key == "env_vars":
            value = unquote(value)
        data[key] = value
    return data


def collect_prefixes() -> list[Path]:
    values = [expand_path(os.environ.get("PROTON_PREFIX", Path.home() / ".proton"))]
    for conf in association_dir().glob("*.conf"):
        prefix = read_key_values(conf).get("prefix")
        if prefix:
            values.append(expand_path(prefix))
    seen = set()
    result = []
    for prefix in values:
        key = str(prefix)
        if key in seen:
            continue
        seen.add(key)
        result.append(prefix)
    return result


def looks_like_wine_prefix(path: Path) -> bool:
    return (
        path.is_dir()
        and (path / "drive_c").is_dir()
        and any((path / name).exists() for name in ("system.reg", "user.reg", "dosdevices"))
    )


def looks_like_compat_prefix(path: Path) -> bool:
    return looks_like_wine_prefix(path / "pfx")


def is_steam_zero_prefix(path: Path) -> bool:
    path = expand_path(path)
    return path.name == "0" and path.parent.name == "compatdata" and path.parent.parent.name == "steamapps"


def add_unique_path(values: list[Path], seen: set[str], path: str | Path) -> None:
    prefix = expand_path(path)
    if is_steam_zero_prefix(prefix):
        return
    key = str(prefix)
    if key in seen:
        return
    seen.add(key)
    values.append(prefix)


def prefix_mtime(prefix: Path) -> float:
    try:
        if looks_like_compat_prefix(prefix):
            return (prefix / "pfx").stat().st_mtime
        return prefix.stat().st_mtime
    except OSError:
        return 0


def process_prefix_from_wineprefix(wineprefix: str) -> Path | None:
    if not wineprefix:
        return None
    path = expand_path(wineprefix)
    if path.name == "pfx" and looks_like_wine_prefix(path):
        return path.parent
    if looks_like_wine_prefix(path):
        return path
    return None


def collect_running_process_prefixes() -> list[Path]:
    counts: dict[str, tuple[Path, int]] = {}
    for proc in Path("/proc").iterdir():
        if not proc.name.isdigit():
            continue
        try:
            environ = (proc / "environ").read_bytes().split(b"\0")
        except OSError:
            continue
        env = {}
        for item in environ:
            if b"=" not in item:
                continue
            key, value = item.split(b"=", 1)
            env[key.decode(errors="replace")] = value.decode(errors="replace")
        wine_prefix = process_prefix_from_wineprefix(env.get("WINEPREFIX", ""))
        if wine_prefix and not is_steam_zero_prefix(wine_prefix):
            key = str(wine_prefix)
            counts[key] = (wine_prefix, counts.get(key, (wine_prefix, 0))[1] + 1)
        steam_data = env.get("STEAM_COMPAT_DATA_PATH", "")
        if steam_data and looks_like_compat_prefix(expand_path(steam_data)):
            prefix = expand_path(steam_data)
            if not is_steam_zero_prefix(prefix):
                key = str(prefix)
                counts[key] = (prefix, counts.get(key, (prefix, 0))[1] + 1)
        wrapper_prefix = env.get("SHORIN_PROTON_WRAPPER_PREFIX", "")
        if wrapper_prefix:
            prefix = expand_path(wrapper_prefix)
            key = str(prefix)
            counts[key] = (prefix, counts.get(key, (prefix, 0))[1] + 1)
    return [prefix for prefix, _count in sorted(counts.values(), key=lambda item: (-item[1], str(item[0])))]


def collect_common_prefixes() -> list[Path]:
    home = Path.home()
    patterns = [
        home / ".wine",
        home / ".local/share/Steam/steamapps/compatdata/*",
        home / ".steam/steam/steamapps/compatdata/*",
        home / ".var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/compatdata/*",
        home / "Games/*",
        home / "games/*",
        home / "Applications/*",
        home / "Wine/*",
        home / "wine/*",
        home / "Prefixes/*",
        home / "prefixes/*",
        home / ".local/share/lutris/prefixes/*",
        home / ".local/share/bottles/bottles/*",
        home / ".var/app/com.usebottles.bottles/data/bottles/bottles/*",
        home / "Games/Heroic/*",
        home / "Games/legendary/*",
        home / "Games/epic/*",
    ]
    values: list[Path] = []
    seen: set[str] = set()
    for pattern in patterns:
        for path in pattern.parent.glob(pattern.name):
            if looks_like_compat_prefix(path) or looks_like_wine_prefix(path):
                add_unique_path(values, seen, path)
    return sorted(values, key=lambda prefix: (-prefix_mtime(prefix), str(prefix)))


def collect_process_prefixes() -> list[Path]:
    values: list[Path] = []
    seen: set[str] = set()
    for group in (collect_running_process_prefixes(), collect_prefixes(), collect_common_prefixes()):
        for prefix in group:
            add_unique_path(values, seen, prefix)
    return values


def parse_steam_manifest_value(line: str, key: str) -> str:
    parts = line.strip().split('"')
    if len(parts) >= 4 and parts[1] == key:
        return parts[3]
    return ""


def steam_app_names() -> dict[str, str]:
    home = Path.home()
    steamapps_dirs = [
        home / ".local/share/Steam/steamapps",
        home / ".var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps",
    ]
    names: dict[str, str] = {}
    for steamapps in steamapps_dirs:
        if not steamapps.is_dir():
            continue
        for manifest in steamapps.glob("appmanifest_*.acf"):
            appid = manifest.stem.removeprefix("appmanifest_")
            name = ""
            try:
                for line in manifest.read_text(errors="ignore").splitlines():
                    name = parse_steam_manifest_value(line, "name")
                    if name:
                        break
            except OSError:
                continue
            if appid and name:
                names[appid] = name
    return names


def steam_app_id_for_prefix(prefix: Path) -> str:
    prefix = expand_path(prefix)
    if prefix.name.isdigit() and prefix.parent.name == "compatdata" and prefix.parent.parent.name == "steamapps":
        return prefix.name
    return ""


def process_prefix_label(prefix: Path, app_names: dict[str, str]) -> str:
    appid = steam_app_id_for_prefix(prefix)
    if appid:
        name = app_names.get(appid, "")
        if name:
            return f"{name} · Steam"
        return f"Steam"
    return str(prefix)


def unique_process_prefix_labels(prefixes: list[Path]) -> list[tuple[str, Path]]:
    app_names = steam_app_names()
    counts: dict[str, int] = {}
    labels = []
    for prefix in prefixes:
        label = process_prefix_label(prefix, app_names)
        labels.append((label, prefix))
        counts[label] = counts.get(label, 0) + 1
    return [
        (f"{label} · {prefix}" if counts[label] > 1 else label, prefix)
        for label, prefix in labels
    ]


def cache_file_for_path(exe: str | Path) -> Path:
    association_dir().mkdir(parents=True, exist_ok=True)
    key = hashlib.sha256(str(exe).encode()).hexdigest()
    return association_dir() / f"{key}.conf"


def parse_runners(output: str) -> list[dict[str, str]]:
    runners = []
    name = kind = source = ""
    for line in output.splitlines():
        if not line.strip():
            continue
        if ":" not in line:
            name = line.strip().removeprefix("* ").strip()
        elif line.startswith("      type:   "):
            kind = line.removeprefix("      type:   ")
        elif line.startswith("      source: "):
            source = line.removeprefix("      source: ")
        elif line.startswith("      path:   "):
            runners.append({
                "name": name,
                "type": kind,
                "source": source,
                "path": line.removeprefix("      path:   "),
            })
    return runners


def load_runners(wrapper: str) -> list[dict[str, str]]:
    try:
        result = subprocess.run([wrapper, "--list-runner"], check=False, text=True, capture_output=True)
    except OSError:
        return []
    return parse_runners(result.stdout)


def runner_label(runner: dict[str, str]) -> str:
    detail = runner.get("source") or runner.get("type")
    return f'{runner["name"]} · {detail}' if detail else runner["name"]


def safe_filename(value: str) -> str:
    cleaned = []
    for char in value:
        if char.isalnum() or char in ".-_":
            cleaned.append(char)
        elif char.isspace():
            cleaned.append("-")
        else:
            cleaned.append("_")
    name = "".join(cleaned).strip("-._")
    return name or "windows-app"


