    def run_path(self, path: str, prefix: str = "", runner: str = "") -> None:
        if not path:
            return
        command = [self.wrapper, "-p", prefix or str(self.current_prefix())]
        if runner and Path(runner).is_file() and os.access(runner, os.X_OK):
            command.extend(["--runner", runner])
        elif "proton-ge" in runner.lower() or "ge-proton" in runner.lower():
            command.extend(["--runner", "ge"])
        elif "dw-proton" in runner.lower() or "dwproton" in runner.lower():
            command.extend(["--runner", "dw"])
        command.append(path)
        subprocess.Popen(command)
        self.set_status(f"{TEXT['run']}: {path}")
        GLib.timeout_add(800, self.refresh_apps_once)

    def refresh_apps_once(self) -> bool:
        self.refresh_apps(force=True)
        self.refresh_install_dirs(force=True)
        return False

