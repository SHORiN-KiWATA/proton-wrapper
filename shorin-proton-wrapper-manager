            return
        text = combo.get_active_text() or ""
        prefix = self.process_prefix_display_paths.get(text)
        if prefix and text != str(prefix):
            self.process_path_label.set_text(str(prefix))
            self.process_path_label.set_visible(True)
        else:
            self.process_path_label.set_text("")
            self.process_path_label.set_visible(False)

